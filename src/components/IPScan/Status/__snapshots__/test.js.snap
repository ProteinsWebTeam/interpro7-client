  <Table
    actualSize={0}
    contentType="result"
    dataTable={[]}
    query={{}}
    rowKey="localID"
    showTableIcon={false}
  >
    <Column
      dataKey="localTitle"
      isSearchable={true}
      isSortable={true}
      renderer={[Function]}
    >
      Job ID
    </Column>
    <Column
      dataKey="entries"
      isSearchable={true}
      isSortable={true}
    >
      Sequences
    </Column>
    <Column
