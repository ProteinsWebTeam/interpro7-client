      dataKey="status"
      headerClassName="table-header-center"
      renderer={[Function]}
    >
      Status
    </Column>
    <Column
      cellClassName="table-center font-ml"
      dataKey="localID"
      defaultKey="actions"
      headerClassName="table-header-center"
      renderer={[Function]}
    >
      Actions
    </Column>
  </Table>
</div>
